# Planilla de configuración (pestañas: providers, product_mapping, stores, …)
CONFIG_TABLE=

# Opcional: stock centralizado para restar del wanted (GLASS / ACCESORIOS).
# Si no están, generate_order usa solo los archivos WANTED por local (stores).
GLASS_TABLE=
ACCESORIOS_TABLE=

# Respaldo si falta link en "stores" (columnas B/C) o en providers (order).
WANTED_GLASS_TABLE=
WANTED_ACCESORIOS_TABLE=
ORDER_GLASS_TABLE=
ORDER_ACCESORIOS_TABLE=

GOOGLE_APPLICATION_CREDENTIALS=./credentials.json
